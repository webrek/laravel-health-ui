{
    "name": "webrek/laravel-health-ui",
    "description": "A production health dashboard for Laravel: pluggable checks, a JSON endpoint for uptime monitors and a status page.",
    "keywords": [
        "laravel",
        "laravel-package",
        "health",
        "health-check",
        "healthcheck",
        "status-page",
        "monitoring",
        "uptime",
        "observability"
    ],
    "homepage": "https://github.com/webrek/laravel-health-ui",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Victor Hernandez",
            "email": "victor@arturohernandez.com.mx"
        }
    ],
    "support": {
        "issues": "https://github.com/webrek/laravel-health-ui/issues",
        "source": "https://github.com/webrek/laravel-health-ui",
        "security": "https://github.com/webrek/laravel-health-ui/security/advisories/new"
    },
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^12.0",
        "illuminate/support": "^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^10.0",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Webrek\\HealthUi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webrek\\HealthUi\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Webrek\\HealthUi\\HealthUiServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M",
        "pint": "pint",
        "pint:check": "pint --test"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
